{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "cloudbeaver chart values",
  "type": "object",
  "properties": {
    "ingressController": {
      "type": "string",
      "enum": ["nginx", "haproxy", "alb", "traefik"]
    },
    "httpScheme": {
      "type": "string",
      "enum": ["http", "https"]
    },
    "cloudProvider": {
      "type": "string",
      "enum": ["None", "aws"]
    },
    "cloudbeaver": {
      "type": "object",
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "imageTag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "resources": {
          "type": "object"
        }
      }
    },
    "backend": {
      "type": "object",
      "properties": {
        "internal_db": {
          "type": "boolean"
        },
        "dbResources": {
          "type": "object"
        }
      }
    },
    "traefik": {
      "type": "object",
      "properties": {
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        }
      }
    }
  }
}
